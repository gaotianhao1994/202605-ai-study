{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "justMyCode": false
        },
        {
            "name": "Python: RAG Splitter Demo",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/demos/20260508_rag_splitter/demo.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/demos/20260508_rag_splitter",
            "justMyCode": false
        },
        {
            "name": "Python: Thinking Reflection Demo",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/demos/20260507_thinking_reflection/demo.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/demos/20260507_thinking_reflection",
            "justMyCode": false
        },
        {
            "name": "Python: Hello World Demo",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/src/demos/20260508_demo/hello_world.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/demos/20260508_demo",
            "justMyCode": false
        },
        {
            "name": "Python: Run Tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-v",
                "${workspaceFolder}/tests"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
}
